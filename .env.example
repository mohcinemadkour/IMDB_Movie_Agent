# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Primary LLM: OpenAI ---
OPENAI_API_KEY=sk-...

# Optional: override the default model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# --- Fallback LLM: Google Gemini ---
# Set LLM_PROVIDER=gemini to use Gemini instead of OpenAI
# GOOGLE_API_KEY=AIza...
# LLM_PROVIDER=openai
# GEMINI_MODEL=gemini-1.5-pro

# --- LangSmith Observability (optional) ---
# Sign up at https://smith.langchain.com to get an API key.
# When set, every agent run is traced in the LangSmith UI with full
# tool call timings, inputs/outputs, and token counts.
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=ls__...
# LANGCHAIN_PROJECT=imdb-movie-agent

# --- Logging ---
# LOG_LEVEL controls verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_FILE controls the log file path (default: logs/app.log).
# Set LOG_FILE= (empty string) to disable file logging and write only to stdout.
# LOG_LEVEL=INFO
# LOG_FILE=logs/app.log

# --- LLM Response Cache ---
# LLM_CACHE: sqlite (default) | memory | none
#   sqlite  — persists across restarts; great for repeated identical queries
#   memory  — in-process only; cleared on restart
#   none    — disables caching (always hits the API)
# LLM_CACHE_DB: path to the SQLite file (default: .cache/llm_cache.db)
# LLM_CACHE=sqlite
# LLM_CACHE_DB=.cache/llm_cache.db
