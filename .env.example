# ════════════════════════════════════════════════════════════════════════════
# IMDB Movie Agent — Environment Configuration
# ════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE THIS FILE:
# 1. Copy this file to .env in the project root:
#    - Windows:  copy .env.example .env
#    - macOS/Linux: cp .env.example .env
#
# 2. Open .env and fill in your API key(s):
#    - REQUIRED: Either OPENAI_API_KEY or GOOGLE_API_KEY
#    - OPTIONAL: All other settings
#
# 3. Restart the app: streamlit run app.py
#
# ⚠️  SECURITY: Never commit .env to Git. It's listed in .gitignore.
# ════════════════════════════════════════════════════════════════════════════

# --- Primary LLM: OpenAI (REQUIRED if not using Google Gemini) ---
# Get your key from: https://platform.openai.com/account/api-keys
# Starts with 'sk-' and is ~48 characters long.
OPENAI_API_KEY=sk-...

# Optional: override the default model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# --- Fallback LLM: Google Gemini ---
# Set LLM_PROVIDER=gemini to use Gemini instead of OpenAI
# GOOGLE_API_KEY=AIza...
# LLM_PROVIDER=openai
# GEMINI_MODEL=gemini-1.5-pro

# --- LangSmith Observability (optional) ---
# Sign up at https://smith.langchain.com to get an API key.
# When set, every agent run is traced in the LangSmith UI with full
# tool call timings, inputs/outputs, and token counts.
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=ls__...
# LANGCHAIN_PROJECT=imdb-movie-agent

# --- Logging ---
# LOG_LEVEL controls verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_FILE controls the log file path (default: logs/app.log).
# Set LOG_FILE= (empty string) to disable file logging and write only to stdout.
# LOG_LEVEL=INFO
# LOG_FILE=logs/app.log

# --- Vector Store Backend ---
# VECTOR_STORE: faiss (default) | pinecone | chroma
#   faiss    — local flat file at data/faiss_index/ (committed to repo; no external service)
#   pinecone — Pinecone serverless index (free tier); requires PINECONE_API_KEY
#   chroma   — ChromaDB; local persistent by default, or remote HTTP if CHROMA_HOST is set
# VECTOR_STORE=faiss
#
# Pinecone settings (only needed when VECTOR_STORE=pinecone):
# PINECONE_API_KEY=pcsk_...
# PINECONE_INDEX_NAME=imdb-movies
#
# ChromaDB settings (only needed when VECTOR_STORE=chroma):
# CHROMA_HOST=              # leave empty for local persistent; set to hostname for remote
# CHROMA_PORT=8000
# CHROMA_COLLECTION=imdb-overviews
# CHROMA_PERSIST_DIR=.chroma   # local persistent directory; ignored when CHROMA_HOST is set

# --- LLM Response Cache ---
# LLM_CACHE: sqlite (default) | memory | none
#   sqlite  — persists across restarts; great for repeated identical queries
#   memory  — in-process only; cleared on restart
#   none    — disables caching (always hits the API)
# LLM_CACHE_DB: path to the SQLite file (default: .cache/llm_cache.db)
# LLM_CACHE=sqlite
# LLM_CACHE_DB=.cache/llm_cache.db
